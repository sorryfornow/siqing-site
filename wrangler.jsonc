{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "siqing-site",
  "compatibility_date": "2026-04-24",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "siqing.site", "custom_domain": true },
    { "pattern": "www.siqing.site", "custom_domain": true }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
